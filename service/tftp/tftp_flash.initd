#!/sbin/openrc-run

description="Auto Router Flash TFTP Server"
command="/usr/bin/python3"
command_args="/opt/Auto_Router_Flash_AIUI/service/tftp/tftp_server.py --daemon"
command_background=true
pidfile="/run/tftp_flash.pid"

depend() {
    need net
    use dns
}

start_pre() {
    checkpath --directory /run
}

stop() {
    local pid
    if [ -f "$pidfile" ]; then
        pid=$(cat "$pidfile")
        kill "$pid" 2>/dev/null
        rm -f "$pidfile"
    fi
}
